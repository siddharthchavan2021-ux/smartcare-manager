# =============================================
# SmartCare Frontend - .gitignore
# =============================================

# ---- Android Build Outputs ----
build/
.gradle/
*.apk
*.aab
*.dex
*.class

# ---- Android Local Config (contains SDK path - machine specific) ----
local.properties

# ---- Android Keystore (signing keys - NEVER push) ----
*.jks
*.keystore
keystore.properties

# ---- IDE Files ----
.idea/
*.iml
*.iws
*.ipr
.vscode/
*.swp

# ---- Gradle Cache ----
.gradle/
gradle/wrapper/gradle-wrapper.jar

# ---- OS Files ----
.DS_Store
Thumbs.db

# ---- Environment & Secrets ----
.env
.env.*
*.env
secrets.properties

# ---- Captures / Profiler output ----
captures/
*.hprof
lint/
