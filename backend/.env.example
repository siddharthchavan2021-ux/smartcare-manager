# =============================================
# SmartCare Node.js Backend — .env TEMPLATE
# =============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub.

# MongoDB Atlas URI
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/smartcare?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_random_secret_key_min_32_chars_here
JWT_EXPIRY=86400000

# Server port
PORT=8080

# Gmail SMTP — for OTP + notification emails
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=smarthealthcaremanagement@gmail.com
MAIL_PASS=obgg rama ssua qgrs
MAIL_FROM=your_gmail@gmail.com

# Admin registration auth codes (comma-separated)
ADMIN_AUTH_CODES=ADMIN-2026,SMARTCARE-ADMIN

# Face recognition threshold (Euclidean distance, default 0.45)
FACE_MATCH_THRESHOLD=0.45
